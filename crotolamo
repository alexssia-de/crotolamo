<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>miau - Registro de Pelis y Series</title>
    <!-- Tailwind CSS para el diseño impecable y oscuro -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <!-- Iconos Lucide (similares a los de las capturas) -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        /* Personalización de la barra de desplazamiento para el estilo oscuro */
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #13121a;
        }
        ::-webkit-scrollbar-thumb {
            background: #2e2a3a;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #4c4460;
        }
    </style>
</head>
<body class="bg-[#0d0c12] text-gray-200 font-sans antialiased min-h-screen">

    <!-- HEADER / NAVBAR (Replicado de image_7.png) -->
    <header class="flex items-center justify-between px-6 py-4 bg-[#13121a] border-b border-[#1f1d29] sticky top-0 z-40">
        <div class="flex items-center gap-6">
            <!-- Logo miau -->
            <span class="text-2xl font-bold tracking-tight text-white flex items-center gap-2">
                🐱 miau
            </span>
            <!-- Buscador principal -->
            <div class="relative hidden md:block w-80">
                <i data-lucide="search" class="absolute left-3 top-2.5 h-4 w-4 text-gray-400"></i>
                <input 
                    type="text" 
                    placeholder="Buscar..." 
                    class="w-full bg-[#1e1c26] text-sm pl-9 pr-4 py-2 rounded-full text-gray-200 border border-transparent focus:outline-none focus:border-purple-500 transition"
                >
            </div>
        </div>
        
        <!-- Botón Añadir -->
        <button 
            onclick="toggleModal(true)"
            class="bg-[#6d28d9] hover:bg-[#5b21b6] text-white px-5 py-2 rounded-xl text-sm font-medium flex items-center gap-2 transition cursor-pointer"
        >
            <i data-lucide="plus" class="h-4 w-4"></i> Añadir
        </button>
    </header>

    <!-- CONTENIDO PRINCIPAL (Estructura de image_7.png y listado de image_5.png) -->
    <main class="max-w-4xl mx-auto mt-8 px-4">
        
        <!-- Tabs de Vistas / Pendientes -->
        <div class="flex gap-6 border-b border-[#1f1d29] pb-0 mb-6">
            <button class="text-white font-semibold border-b-2 border-purple-500 pb-3 px-1 flex items-center gap-1.5 cursor-pointer">
                <i data-lucide="clapperboard" class="h-4 w-4 text-purple-400"></i>
                Vistas 
                <span class="bg-[#1e1c26] text-gray-400 text-xs px-2 py-0.5 rounded-full ml-1">2</span>
            </button>
            <button class="text-gray-400 hover:text-white pb-3 px-1 flex items-center gap-1.5 transition cursor-pointer">
                <i data-lucide="bookmark" class="h-4 w-4 text-gray-500"></i>
                Pendientes 
                <span class="bg-[#1e1c26] text-gray-500 text-xs px-2 py-0.5 rounded-full ml-1">0</span>
            </button>
        </div>

        <!-- Filtros superiores (Estilo image_5.png) -->
        <div class="flex items-center justify-between mb-4 text-xs text-gray-400">
            <div class="flex gap-2">
                <button class="bg-[#1e1c26] hover:bg-[#252230] px-3 py-1.5 rounded-lg flex items-center gap-1 transition cursor-pointer">
                    <i data-lucide="layout-grid" class="h-3.5 w-3.5"></i> Mural
                </button>
                <button class="bg-[#2a2538] text-purple-300 px-3 py-1.5 rounded-lg flex items-center gap-1 cursor-pointer">
                    <i data-lucide="list" class="h-3.5 w-3.5"></i> Lista
                </button>
                <button class="bg-[#1e1c26] hover:bg-[#252230] px-3 py-1.5 rounded-lg flex items-center gap-1 transition cursor-pointer">
                    Géneros <i data-lucide="chevron-down" class="h-3 w-3"></i>
                </button>
            </div>
            <button class="bg-[#1e1c26] hover:bg-[#252230] px-3 py-1.5 rounded-lg flex items-center gap-1 transition cursor-pointer">
                Año ↓ (recientes) <i data-lucide="chevron-down" class="h-3 w-3"></i>
            </button>
        </div>

        <!-- LISTA DE SERIES GUARDADAS -->
        <div class="space-y-2" id="lista-series">
            <!-- Item 1: Big Bang -->
            <div class="flex items-center justify-between p-3 bg-[#13121a] hover:bg-[#181622] rounded-xl transition border border-transparent hover:border-[#262333]">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-16 bg-gray-800 rounded-lg overflow-hidden flex-shrink-0">
                        <img src="https://images.themoviedb.org/t/p/w200/oo83Z6v4g6zA29vS6f886gT86Cc.jpg" alt="Big Bang" class="w-full h-full object-cover">
                    </div>
                    <div>
                        <h3 class="font-medium text-white text-sm md:text-base">Big Bang</h3>
                        <p class="text-xs text-gray-400">The Big Bang Theory</p>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-[11px] bg-[#064e3b] text-[#10b981] px-2.5 py-1 rounded-full flex items-center gap-1 font-medium">
                        <i data-lucide="check" class="h-3 w-3"></i> Vista
                    </span>
                    <!-- Contador de vistas tipo image_5.png -->
                    <div class="flex items-center bg-[#1e1c26] rounded-lg p-0.5 border border-[#2e2a3a]">
                        <button class="p-1 hover:text-white"><i data-lucide="chevron-left" class="h-3.5 w-3.5"></i></button>
                        <span class="text-xs px-2 font-mono text-white">× 1</span>
                        <button class="p-1 hover:text-white"><i data-lucide="chevron-right" class="h-3.5 w-3.5"></i></button>
                    </div>
                </div>
            </div>

            <!-- Item 2: Martin Mystery -->
            <div class="flex items-center justify-between p-3 bg-[#13121a] hover:bg-[#181622] rounded-xl transition border border-transparent hover:border-[#262333]">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-16 bg-gray-800 rounded-lg overflow-hidden flex-shrink-0">
                        <img src="https://images.themoviedb.org/t/p/w200/4Sbyu0fGez9vD2B3FmOcrL3lFv3.jpg" alt="Martin Mystery" class="w-full h-full object-cover">
                    </div>
                    <div>
                        <h3 class="font-medium text-white text-sm md:text-base">Martin Mystery</h3>
                        <p class="text-xs text-gray-400">Martin Mystère</p>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-[11px] bg-[#064e3b] text-[#10b981] px-2.5 py-1 rounded-full flex items-center gap-1 font-medium">
                        <i data-lucide="check" class="h-3 w-3"></i> Vista
                    </span>
                    <div class="text-xs text-gray-400 font-mono pr-2">× 26</div>
                </div>
            </div>
        </div>
    </main>

    <!-- MODAL PARA AÑADIR SERIE (Escondido por defecto - Controlado con JS) -->
    <div id="modal-add" class="fixed inset-0 bg-black/70 backdrop-blur-xs hidden items-center justify-center p-4 z-50 transition-all">
        <div class="bg-[#13121a] w-full max-w-md rounded-2xl p-5 border border-[#23212f] relative shadow-2xl">
            
            <!-- Encabezado Modal -->
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-base font-semibold text-white">Añadir serie</h2>
                <button onclick="toggleModal(false)" class="text-gray-400 hover:text-white p-1 rounded-lg hover:bg-[#1e1c26] transition cursor-pointer">
                    <i data-lucide="x" class="h-5 w-5"></i>
                </button>
            </div>

            <!-- Input Buscador (Replicando image_6.png) -->
            <div class="relative mb-3">
                <i data-lucide="search" class="absolute left-3 top-3 h-4 w-4 text-gray-400"></i>
                <input 
                    type="text"
                    id="search-input"
                    oninput="handleSearch(this.value)"
                    placeholder="Título, creador, actor o productora..." 
                    class="w-full bg-[#1e1c26] text-sm pl-9 pr-4 py-2.5 rounded-xl text-gray-200 border border-[#2e2a3a] focus:outline-none focus:border-purple-500 transition"
                >
            </div>

            <!-- Alerta informativa (Estilo image_4.png / image_2.png) -->
            <div id="search-alert" class="hidden bg-[#2a1e15] border border-[#52351a] text-[#e0a96d] px-3 py-2 rounded-xl text-xs flex items-center gap-2 mb-3">
                <i data-lucide="alert-triangle" class="h-4 w-4 flex-shrink-0"></i>
                <span>Ya tienes «El asombroso mundo de Gumball» en tu lista.</span>
            </div>

            <!-- Filtros internos del modal (Replicado de image_4.png) -->
            <div class="flex gap-1.5 overflow-x-auto pb-2 mb-3 text-[11px] font-medium" id="modal-filters">
                <button class="bg-[#6d28d9] text-white px-3 py-1 rounded-full cursor-pointer">Todo</button>
                <button class="bg-[#1e1c26] text-gray-400 hover:text-white px-3 py-1 rounded-full transition cursor-pointer">Series 11</button>
                <button class="bg-[#1e1c26] text-gray-400 hover:text-white px-3 py-1 rounded-full transition cursor-pointer">Personas 2</button>
                <button class="bg-[#1e1c26] text-gray-400 hover:text-white px-3 py-1 rounded-full transition cursor-pointer">Productoras 3</button>
            </div>

            <!-- Lista de Resultados Dinámicos -->
            <div class="text-xs text-gray-400 mb-2 font-semibold tracking-wider uppercase">Series</div>
            <div class="space-y-1 max-h-64 overflow-y-auto pr-1" id="resultados-busqueda">
                <!-- Estado Inicial vacío (image_6.png) -->
                <p id="placeholder-text" class="text-center text-xs text-gray-500 my-10">
                    Escribe un título para buscarlo en TMDb.
                </p>
            </div>
        </div>
    </div>

    <!-- NOTIFICACIÓN INTERNA SIMULADA (Estilo el toast de éxito en image_4.png) -->
    <div id="toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 bg-[#1c1a26] border border-[#2d293d] px-4 py-2.5 rounded-full text-xs text-gray-200 shadow-xl flex items-center gap-2 transition-all transform translate-y-20 opacity-0 z-50">
        <i data-lucide="check-circle-2" class="h-4 w-4 text-emerald-400"></i>
        <span id="toast-text">Añadida correctamente</span>
    </div>

    <!-- JAVASCRIPT LOGIC -->
    <script>
        // Inicializar los iconos de Lucide al cargar la página
        lucide.createIcons();

        // Control del Modal
        function toggleModal(open) {
            const modal = document.getElementById('modal-add');
            if (open) {
                modal.classList.remove('hidden');
                modal.classList.add('flex');
                document.getElementById('search-input').focus();
            } else {
                modal.classList.remove('flex');
                modal.classList.add('hidden');
                // Resetear buscador al cerrar
                document.getElementById('search-input').value = '';
                handleSearch('');
            }
        }

        // Simulación de Base de Datos de Búsqueda (Simulando API de TMDB)
        const baseDeDatosSimulada = [
            { id: 101, title: 'El asombroso mundo de Gumball', year: '2011', image: 'https://images.themoviedb.org/t/p/w200/96LpZofw0v79f6w4S3g6R520S7k.jpg', yaExiste: true },
            { id: 102, title: 'El maravillosamente extraño mundo de Gumball', year: '2025', image: 'https://images.themoviedb.org/t/p/w200/96LpZofw0v79f6w4S3g6R520S7k.jpg', yaExiste: false },
            { id: 103, title: 'Zulu Gumball', year: '2010', image: '', yaExiste: false },
            { id: 104, title: 'Gumball 3000', year: '2020', image: '', yaExiste: false }
        ];

        // Lógica del buscador reactivo
        function handleSearch(query) {
            const container = document.getElementById('resultados-busqueda');
            const placeholder = document.getElementById('placeholder-text');
            const alertBox = document.getElementById('search-alert');
            
            if (!query.trim()) {
                container.innerHTML = '';
                container.appendChild(placeholder);
                alertBox.classList.add('hidden');
                return;
            }

            // Quitar texto vacío
            if (placeholder) placeholder.remove();

            // Filtrar elementos según el texto introducido
            const resultados = baseDeDatosSimulada.filter(item => 
                item.title.toLowerCase().includes(query.toLowerCase())
            );

            if (resultados.length === 0) {
                container.innerHTML = `<p class="text-center text-gray-500 my-6">No se encontraron resultados para "${query}"</p>`;
                alertBox.classList.add('hidden');
                return;
            }

            // Mostrar alerta de 'ya existe' si el primero de la lista simulada está presente (Replicando image_4.png)
            if (resultados.some(r => r.yaExiste)) {
                alertBox.classList.remove('hidden');
            } else {
                alertBox.classList.add('hidden');
            }

            // Renderizar los resultados con estructura exacta de las fotos
            container.innerHTML = resultados.map(item => `
                <div class="flex items-center justify-between p-2 hover:bg-[#1e1c26] rounded-xl transition group">
                    <div class="flex items-center gap-3">
                        <div class="w-9 h-12 bg-[#1f1d29] rounded overflow-hidden flex-shrink-0 flex items-center justify-center">
                            ${item.image ? `<img src="${item.image}" class="w-full h-full object-cover">` : `<i data-lucide="clapperboard" class="h-4 w-4 text-gray-600"></i>`}
                        </div>
                        <div>
                            <p class="text-sm font-medium ${item.yaExiste ? 'text-gray-400' : 'text-white'}">${item.title}</p>
                            <p class="text-xs text-gray-500">${item.year}</p>
                        </div>
                    </div>
                    <div>
                        ${item.yaExiste 
                            ? `<span class="p-1.5 text-emerald-500 flex items-center justify-center"><i data-lucide="check-circle" class="h-5 w-5"></i></span>`
                            : `<button onclick="agregarNuevaSerie('${item.title}', '${item.image}')" class="p-1.5 bg-[#1e1c26] text-purple-400 hover:bg-[#6d28d9] hover:text-white rounded-full transition cursor-pointer">
                                    <i data-lucide="plus" class="h-4 w-4"></i>
                               </button>`
                        }
                    </div>
                </div>
            `).join('');

            // Volver a procesar los iconos insertados dinámicamente
            lucide.createIcons();
        }

        // Función para simular el guardado y el Toast de éxito (image_4.png abajo)
        function agregarNuevaSerie(titulo, imagenUrl) {
            toggleModal(false);

            // Agregar a la lista visible de la pantalla principal
            const lista = document.getElementById('lista-series');
            const nuevoItem = document.createElement('div');
            nuevoItem.className = "flex items-center justify-between p-3 bg-[#13121a] hover:bg-[#181622] rounded-xl transition border border-transparent hover:border-[#262333]";
            nuevoItem.innerHTML = `
                <div class="flex items-center gap-4">
                    <div class="w-12 h-16 bg-gray-800 rounded-lg overflow-hidden flex-shrink-0">
                        <img src="${imagenUrl || 'https://via.placeholder.com/200'}" class="w-full h-full object-cover">
                    </div>
                    <div>
                        <h3 class="font-medium text-white text-sm md:text-base">${titulo}</h3>
                        <p class="text-xs text-gray-400">${titulo}</p>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-[11px] bg-[#064e3b] text-[#10b981] px-2.5 py-1 rounded-full flex items-center gap-1 font-medium">
                        <i data-lucide="check" class="h-3 w-3"></i> Vista
                    </span>
                    <div class="text-xs text-gray-400 font-mono pr-2">× 1</div>
                </div>
            `;
            lista.prepend(nuevoItem);
            lucide.createIcons();

            // Lanzar notificación Toast flotante abajo
            const toast = document.getElementById('toast');
            document.getElementById('toast-text').innerText = `Añadida «${titulo}»`;
            toast.classList.remove('translate-y-20', 'opacity-0');
            
            setTimeout(() => {
                toast.classList.add('translate-y-20', 'opacity-0');
            }, 3000);
        }
    </script>
</body>
</html>
